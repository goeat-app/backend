{
  "rootDir": "../",
  "testMatch": ["<rootDir>/test/integration/**/*.test.ts"],
  "moduleFileExtensions": ["js", "json", "ts"],
  "transform": {
    "^.+\\.(t|j)s$": [
      "ts-jest",
      { "tsconfig": "<rootDir>/test/tsconfig.test.json" }
    ]
  },
  "testEnvironment": "node",
  "setupFiles": ["<rootDir>/test/jest-env.ts"],
  "testTimeout": 60000,
  "forceExit": true,
  "verbose": true
}
